# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=library_occupancy
POSTGRES_USER=library_app
POSTGRES_PASSWORD=change_me_strong_password_here

DATABASE_URL=postgresql://library_app:change_me_strong_password_here@db:5432/library_occupancy

# ─── API Service ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_me_different_secret_openssl_rand_hex_64

# Generate with: openssl rand -hex 32
JETSON_API_KEY=change_me_generate_with_openssl_rand_hex_32

# Internal ML service URL (Docker network)
ML_SERVICE_URL=http://ml:3002

# Shared secret for API ↔ ML service communication
# Generate with: openssl rand -hex 32
ML_SECRET=change_me_internal_ml_secret_openssl_rand_hex_32

# Allowed origin for dashboard (CORS) — set to your production domain
CORS_ORIGIN=https://library.example.com

# ─── Frontend ────────────────────────────────────────────────────────────────
# Public-facing API base URL (as seen from the browser)
NEXT_PUBLIC_API_URL=https://library.example.com

# ─── Scheduler / External APIs ───────────────────────────────────────────────
OPEN_METEO_URL=https://api.open-meteo.com
# Historical Forecast API (not the Archive/ERA5 API) -- used to backfill
# weather for past occupancy data with the same distribution the model sees
# from the live forecast API at inference time. See README's Weather section.
OPEN_METEO_HISTORICAL_URL=https://historical-forecast-api.open-meteo.com
NAGER_DATE_URL=https://date.nager.at

# ISO 3166-1 alpha-2 country code for public holidays
COUNTRY_CODE=DE

# Nager.Date subdivision code for state-level public holidays (e.g. DE-BB for
# Brandenburg) -- without this, holidays that aren't nationwide (such as
# Reformationstag) are silently missed.
HOLIDAY_SUBDIVISION=DE-BB

# Library GPS coordinates are NOT read from the environment -- fetchWeather.js
# reads library_lat/library_lon from the `config` DB table instead, so that
# it can be changed from the dashboard without a redeploy. See the "Config
# Keys" section of README.md.

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
